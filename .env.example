# ===========================================
# AttendChain - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# --- Supabase (get from: supabase.com → your project → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # SECRET! Never expose to browser

# --- Stellar / Soroban ---
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
INSTITUTION_SECRET=                   # Stellar secret key (starts with S...)
CONTRACT_ID=                          # Soroban contract ID (starts with C...)

# --- App ---
QR_SECRET=                            # Random string for HMAC-signing QR tokens
NEXT_PUBLIC_APP_URL=http://localhost:3000
